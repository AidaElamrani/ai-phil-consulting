<button
	type="button"
	class="theme-button"
	data-theme-button
	aria-label="Switch to dark theme"
	title="Toggle theme"
>
	<span class="theme-button__icon theme-button__icon--moon" aria-hidden="true">
		<svg viewBox="0 0 24 24" focusable="false">
			<path
				d="M20.742 13.045A8.088 8.088 0 0 1 10.955 3.258 9 9 0 1 0 20.742 13.045Z"
				fill="currentColor"
			/>
		</svg>
	</span>
	<span class="theme-button__icon theme-button__icon--sun" aria-hidden="true">
		<svg viewBox="0 0 24 24" focusable="false">
			<circle cx="12" cy="12" r="4.25" fill="currentColor" />
			<path
				d="M12 1.75a.75.75 0 0 1 .75.75v2.1a.75.75 0 0 1-1.5 0V2.5a.75.75 0 0 1 .75-.75Zm0 16.65a.75.75 0 0 1 .75.75v2.1a.75.75 0 0 1-1.5 0v-2.1a.75.75 0 0 1 .75-.75Zm10.25-7.15a.75.75 0 0 1 0 1.5h-2.1a.75.75 0 0 1 0-1.5h2.1ZM4.6 12a.75.75 0 0 1-.75.75H1.75a.75.75 0 0 1 0-1.5h2.1A.75.75 0 0 1 4.6 12Zm14.648-6.398a.75.75 0 0 1 0 1.06l-1.485 1.485a.75.75 0 0 1-1.06-1.06l1.484-1.485a.75.75 0 0 1 1.061 0ZM7.297 16.703a.75.75 0 0 1 0 1.06l-1.485 1.485a.75.75 0 1 1-1.06-1.06l1.484-1.485a.75.75 0 0 1 1.061 0Zm11.951 2.545a.75.75 0 0 1-1.06 0l-1.485-1.484a.75.75 0 1 1 1.06-1.061l1.485 1.485a.75.75 0 0 1 0 1.06ZM7.297 7.297a.75.75 0 0 1-1.06 0L4.75 5.812a.75.75 0 1 1 1.06-1.06l1.486 1.484a.75.75 0 0 1 0 1.061Z"
				fill="currentColor"
			/>
		</svg>
	</span>
</button>

<script>
	const STORAGE_KEY = 'site-theme';
	const LIGHT_THEME = 'light';
	const DARK_THEME = 'dark';

	const getIsDarkTheme = () => document.documentElement.classList.contains('theme-dark');

	const applyTheme = (theme) => {
		const isDark = theme === DARK_THEME;
		document.documentElement.classList.toggle('theme-dark', isDark);

		document.querySelectorAll('[data-theme-button]').forEach((button) => {
			button.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
		});
	};

	const savedTheme = localStorage.getItem(STORAGE_KEY);
	if (savedTheme === LIGHT_THEME || savedTheme === DARK_THEME) {
		applyTheme(savedTheme);
	} else {
		applyTheme(getIsDarkTheme() ? DARK_THEME : LIGHT_THEME);
	}

	document.querySelectorAll('[data-theme-button]').forEach((button) => {
		button.addEventListener('click', () => {
			const nextTheme = getIsDarkTheme() ? LIGHT_THEME : DARK_THEME;
			applyTheme(nextTheme);
			localStorage.setItem(STORAGE_KEY, nextTheme);
		});
	});
</script>

<style>
	.theme-button {
		display: inline-grid;
		place-items: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		border: 0;
		border-radius: 999rem;
		color: var(--gray-300);
		background: transparent;
		cursor: pointer;
		transition:
			color var(--theme-transition),
			opacity var(--theme-transition),
			background-color var(--theme-transition);
	}

	.theme-button:hover,
	.theme-button:focus-visible {
		color: var(--gray-100);
		background-color: var(--accent-subtle-overlay);
		opacity: 1;
	}

	.theme-button:focus-visible {
		outline: 2px solid var(--accent-regular);
		outline-offset: 2px;
	}

	.theme-button__icon {
		grid-area: 1 / 1;
		display: inline-grid;
		place-items: center;
		width: 1.05rem;
		height: 1.05rem;
		transition:
			transform var(--theme-transition),
			opacity var(--theme-transition);
	}

	.theme-button__icon svg {
		width: 100%;
		height: 100%;
	}

	.theme-button__icon--sun {
		opacity: 0;
		transform: scale(0.8) rotate(-15deg);
	}

	:global(:root.theme-dark) .theme-button__icon--moon {
		opacity: 0;
		transform: scale(0.8) rotate(15deg);
	}

	:global(:root.theme-dark) .theme-button__icon--sun {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}
</style>
