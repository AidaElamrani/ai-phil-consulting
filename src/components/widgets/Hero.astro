---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),
  ornament = await Astro.slots.render('ornament'),

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative md:-mt-[56px] not-prose" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6">
    <div class="pt-0 md:pt-[56px] pointer-events-none"></div>
    <div class="py-12 md:py-14 lg:py-16">
      <div class="mx-auto max-w-[80rem]">
        <div class="relative grid items-start gap-y-10 lg:grid-cols-[minmax(0,0.44fr)_minmax(0,0.56fr)] lg:gap-x-[clamp(4.5rem,7vw,5.625rem)]">
          {
            ornament && (
              <div class="pointer-events-none absolute inset-0 overflow-visible" aria-hidden="true">
                <Fragment set:html={ornament} />
              </div>
            )
          }
          <div class="relative z-10 flex flex-col justify-start lg:items-end lg:pt-2 lg:text-right">
            {
              tagline && (
                <p
                  class="text-base font-bold uppercase tracking-wide text-secondary motion-safe:animate-hero-fade dark:text-blue-200"
                  set:html={tagline}
                />
              )
            }
            {
              title && (
                <h1
                  class="mb-5 font-heading text-[clamp(3.4rem,7vw,5.4rem)] font-black leading-[0.95] tracking-[-0.03em] text-slate-900 motion-safe:animate-hero-fade lg:mb-6"
                  set:html={title}
                />
              )
            }
            <div class="max-w-[36rem] lg:ml-auto lg:max-w-[34rem]">
              {
                subtitle && (
                  <p
                    class="mb-7 max-w-[36rem] font-sans text-[clamp(1.2rem,2vw,1.6rem)] font-normal leading-[1.35] text-[rgb(39_44_52_/_.78)] motion-safe:animate-hero-fade lg:mb-7"
                    set:html={subtitle}
                  />
                )
              }
              {
                actions && (
                  <div class="flex max-w-xs flex-col flex-nowrap gap-4 motion-safe:animate-hero-fade sm:max-w-md sm:flex-row sm:justify-start lg:max-w-none lg:justify-end lg:mt-auto">
                    {Array.isArray(actions) ? (
                      actions.map((action) => (
                        <div class="flex w-full sm:w-auto">
                          <Button {...(action || {})} class="w-full sm:mb-0" />
                        </div>
                      ))
                    ) : (
                      <Fragment set:html={actions} />
                    )}
                  </div>
                )
              }
            </div>
          </div>
          {content && (
            <div class="relative z-10 lg:self-stretch lg:pt-3">
              <div class="relative mx-auto w-fit max-w-full lg:mx-0 lg:h-full lg:w-full">
                <div class="relative z-10 motion-safe:animate-hero-fade" set:html={content} />
              </div>
            </div>
          )}
        </div>
      </div>
      <div
        class="intersect-once intersect-no-queue intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        {
          image && (
            <div class="relative m-auto max-w-5xl">
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class="mx-auto rounded-md w-full"
                  widths={[400, 768, 1024, 2040]}
                  sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                  loading="eager"
                  width={1024}
                  height={576}
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
