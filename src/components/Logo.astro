---
import siteLogo from '~/assets/images/logo-thin-variation.svg';
---

<span class="flex items-center gap-3 leading-none">
  <img src={siteLogo.src} alt="AI-Phil Consulting" class="block h-10 md:h-9 w-auto flex-none" loading="eager" />
  <span class="flex flex-col justify-center">
    <span class="font-heading text-[1.35rem] md:text-[1.2rem] font-[600] text-heading whitespace-nowrap"
      >AI-Phil Consulting</span
    >
    <span class="mt-1 text-[0.62rem] font-medium uppercase tracking-[0.24em] text-brand-eiffel whitespace-nowrap"
      >PARIS</span
    >
  </span>
</span>
