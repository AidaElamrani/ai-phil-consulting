---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter', system-ui, sans-serif;
    --aw-font-serif: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    --aw-font-heading: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;

    --aw-color-background: #f4f1ec;
    --aw-color-surface: #eae5dd;
    --aw-color-border: #d8d1c7;
    --aw-color-text-primary: #2f2f2f;
    --aw-color-text-secondary: #4b5563;
    --aw-color-text-muted: #6b7280;
    --aw-color-accent: #2f5d7c;
    --aw-color-accent-hover: #3e7fa3;
    --aw-color-accent-soft: #a7c7e7;
    --aw-color-brand-eiffel: #6b5a49;
    --aw-color-brand-eiffel-soft: #ae9d85;

    --aw-color-primary: var(--aw-color-accent);
    --aw-color-secondary: var(--aw-color-accent-hover);
    --aw-color-text-heading: var(--aw-color-text-primary);
    --aw-color-text-default: var(--aw-color-text-secondary);
    --aw-color-bg-page: var(--aw-color-background);
    --aw-color-bg-page-dark: var(--aw-color-background);
    --aw-color-text-page: var(--aw-color-text-primary);

    ::selection {
      background-color: rgb(167 199 231 / 42%);
      color: var(--aw-color-text-primary);
    }
  }

  .dark {
    --aw-font-sans: 'Inter', system-ui, sans-serif;
    --aw-font-serif: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    --aw-font-heading: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;

    --aw-color-primary: var(--aw-color-accent);
    --aw-color-secondary: var(--aw-color-accent-hover);
    --aw-color-text-heading: var(--aw-color-text-primary);
    --aw-color-text-default: var(--aw-color-text-secondary);
    --aw-color-bg-page: var(--aw-color-background);
    --aw-color-bg-page-dark: var(--aw-color-background);
    --aw-color-text-page: var(--aw-color-text-primary);

    ::selection {
      background-color: rgb(167 199 231 / 42%);
      color: var(--aw-color-text-primary);
    }
  }
</style>
