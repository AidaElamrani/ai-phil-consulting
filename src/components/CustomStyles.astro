---
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/newsreader/500.css';
import '@fontsource/newsreader/600.css';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'IBM Plex Sans';
    --aw-font-serif: 'Newsreader';
    --aw-font-heading: 'Newsreader';

    --aw-color-primary: rgb(39 56 78);
    --aw-color-secondary: rgb(27 41 58);
    --aw-color-accent: rgb(154 122 88);

    --aw-color-text-heading: rgb(27 31 36);
    --aw-color-text-default: rgb(39 44 52);
    --aw-color-text-muted: rgb(39 44 52 / 72%);
    --aw-color-bg-page: rgb(248 246 241);

    --aw-color-bg-page-dark: rgb(248 246 241);

    ::selection {
      background-color: rgb(225 214 195);
    }
  }

  .dark {
    --aw-font-sans: 'IBM Plex Sans';
    --aw-font-serif: 'Newsreader';
    --aw-font-heading: 'Newsreader';

    --aw-color-primary: rgb(39 56 78);
    --aw-color-secondary: rgb(27 41 58);
    --aw-color-accent: rgb(154 122 88);

    --aw-color-text-heading: rgb(27 31 36);
    --aw-color-text-default: rgb(39 44 52);
    --aw-color-text-muted: rgb(39 44 52 / 72%);
    --aw-color-bg-page: rgb(248 246 241);

    ::selection {
      background-color: rgb(225 214 195);
      color: rgb(27 31 36);
    }
  }
</style>
