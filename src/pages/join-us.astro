            country: getValue('identity[country]'),
            institution: getValue('identity[institution]'),
            position_title: getValue('identity[position_title]'),
            website: getValue('identity[website]'),
            linkedin: getValue('identity[linkedin]'),
          },
          expertise: {
            areas: {
              computer_science_ai: getChecked('expertise[areas][computer_science_ai]'),
              engineering_robotics: getChecked('expertise[areas][engineering_robotics]'),
              cognitive_science_neuroscience: getChecked('expertise[areas][cognitive_science_neuroscience]'),
              natural_sciences: getChecked('expertise[areas][natural_sciences]'),
              philosophy_ethics: getChecked('expertise[areas][philosophy_ethics]'),
              social_sciences: getChecked('expertise[areas][social_sciences]'),
              policy_governance_public_affairs: getChecked('expertise[areas][policy_governance_public_affairs]'),
              law_regulation: getChecked('expertise[areas][law_regulation]'),
              business_strategy_innovation: getChecked('expertise[areas][business_strategy_innovation]'),
              finance_economics: getChecked('expertise[areas][finance_economics]'),
              education_pedagogy: getChecked('expertise[areas][education_pedagogy]'),
              health_care_psychology: getChecked('expertise[areas][health_care_psychology]'),
              arts_design_creative_practice: getChecked('expertise[areas][arts_design_creative_practice]'),
              media_entertainment_communication: getChecked('expertise[areas][media_entertainment_communication]'),
              other: getChecked('expertise[areas][other]'),
            },
            details: {
              specify_further: getValue('expertise[details][specify_further]'),
            },
          },
          employment: {
            situation: {
              employed_private_sector: getChecked('employment[situation][employed_private_sector]'),
              employed_public_sector_academia: getChecked('employment[situation][employed_public_sector_academia]'),
              independent_freelancer: getChecked('employment[situation][independent_freelancer]'),
              consultant_via_company: getChecked('employment[situation][consultant_via_company]'),
              founder_entrepreneur: getChecked('employment[situation][founder_entrepreneur]'),
              student: getChecked('employment[situation][student]'),
              between_positions: getChecked('employment[situation][between_positions]'),
              other: getChecked('employment[situation][other]'),
            },
            details: {
              specify: getValue('employment[details][specify]'),
            },
          },
          contribution: {
            formats: {
              talks: getChecked('contribution[formats][talks]'),
              panels: getChecked('contribution[formats][panels]'),
              workshops: getChecked('contribution[formats][workshops]'),
              courses: getChecked('contribution[formats][courses]'),
              research: getChecked('contribution[formats][research]'),
              writing: getChecked('contribution[formats][writing]'),
              advisory: getChecked('contribution[formats][advisory]'),
              podcast_media: getChecked('contribution[formats][podcast_media]'),
              mentoring: getChecked('contribution[formats][mentoring]'),
              creative_collaboration: getChecked('contribution[formats][creative_collaboration]'),
              other: getChecked('contribution[formats][other]'),
            },
            details: {
              specify_further: getValue('contribution[details][specify_further]'),
            },
          },
          practical: {
            languages: {
              english: getChecked('practical[languages][english]'),
              french: getChecked('practical[languages][french]'),
              other: getChecked('practical[languages][other]'),
            },
            languages_other_detail: getValue('practical[languages_other_detail]'),
            can_travel: getChecked('practical[can_travel]'),
            availability_level: getValue('practical[availability_level]'),
          },
          narrative: {
            short_bio: getValue('narrative[short_bio]'),
            motivation: getValue('narrative[motivation]'),
            relevant_experience: getValue('narrative[relevant_experience]'),
          },
          consent: {
            contact_opportunities: getChecked('consent[contact_opportunities]'),
            data_storage: getChecked('consent[data_storage]'),
          },
        };

        payloadField.value = JSON.stringify(payload);
      }

      form.addEventListener('input', updateStructuredPayload);
      form.addEventListener('change', updateStructuredPayload);
      form.addEventListener('submit', updateStructuredPayload);
      updateStructuredPayload();
    })();
  </script>
