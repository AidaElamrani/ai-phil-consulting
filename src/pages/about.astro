---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};

const sections = [
  {
    title: 'Mission',
    paragraphs: [
      'AI is evolving rapidly, while our ways of understanding and discussing it struggle to keep pace. Important questions are often simplified, avoided, or addressed within constraints that limit how they can be expressed.',
      'At the same time, a great deal of expertise exists across disciplines, yet too little of it reaches public and organizational decision-making in forms that are both rigorous and usable.',
      'AI-Phil Consulting exists to help bridge that gap: to bring forward clear, responsible, and well-grounded insight at a time when it is most needed.',
    ],
  },
  {
    title: 'How we operate',
    paragraphs: [
      'We begin with the question itself, especially when it is complex, sensitive, or insufficiently explored. Rather than relying on standardized methodologies or pre-formatted deliverables, we build each engagement around the problem at hand.',
      'We assemble small, purpose-built collaborations and work in focused formats that prioritize depth, clarity, and relevance. This allows us to address questions that do not fit conventional consulting models, and to produce insights that are both rigorous and usable.',
      'Based in Paris and connected to international networks, we work across contexts and can establish confidentiality frameworks whenever open and responsible analysis requires them.',
    ],
  },
  {
    title: 'Who we help',
    paragraphs: [
      'We support organizations and individuals seeking to engage wisely with complex questions related to AI.',
      'Our work is especially suited to situations where clarity matters, where decisions carry weight, and where standard approaches fall short.',
      'We collaborate with people and institutions who value careful thinking, honest communication, and real-world impact.',
    ],
  },
];
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden px-4 pb-8 pt-4 sm:px-6 md:-mt-[56px] md:pt-[80px] lg:pb-10">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute inset-x-0 top-0 h-40 bg-[radial-gradient(circle_at_top,rgba(154,122,88,0.06),transparent_72%)]"
      >
      </div>
      <div
        class="absolute right-[12%] top-24 hidden h-56 w-56 rounded-full border border-[rgba(39,56,78,0.04)] lg:block"
      >
      </div>
    </div>

    <div class="relative mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-5 text-[0.74rem] font-semibold uppercase tracking-[0.28em] text-secondary/80">About</p>
        <h1
          class="mb-6 font-heading text-[clamp(3.4rem,7vw,5.4rem)] font-black leading-[0.94] tracking-[-0.03em] text-heading lg:mb-7"
        >
          We love AI and wisdom
        </h1>
        <div
  class="mx-auto mb-9 max-w-[36rem] text-left text-[clamp(1.1rem,1.8vw,1.4rem)] leading-[1.6] text-secondary/90 lg:mb-10 space-y-2"
>
  <p>
    <span class="font-semibold italic text-stone-600">Artificial Intelligence</span> — the imitation of human thinking through techno-scientific means.
  </p>

  <p>
    <span class="font-semibold italic text-stone-600">Phil</span> — from the Greek for love; as in philosophy: the love of wisdom.
  </p>
</div>
<div
  class="mx-auto mb-9 max-w-[36rem] text-center text-[clamp(1.1rem,1.8vw,1.4rem)] leading-[1.6] text-secondary/90 lg:mb-10 space-y-2"
>
  <p class="pt-2">
    <span class="font-semibold italic text-stone-600">AI-Phil</span> brings these threads together.
  </p>
</div>
      </div>
    </div>
  </section>

  <section class="px-4 pb-20 pt-6 sm:px-6 md:pt-8 lg:pb-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl">
        {
          sections.map((section, index) => (
            <section class:list={['py-10 sm:py-12 lg:py-14', index !== 0 && 'border-t border-stone-200/70']}>
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-secondary/78">{section.title}</p>
              <div class="mt-6 space-y-5 text-[1.02rem] leading-[1.95] text-[rgb(39_44_52_/_.76)] sm:text-[1.08rem]">
                {section.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
