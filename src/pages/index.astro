---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import HeroMark from '~/components/hero/HeroMark.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'AI-Phil Consulting',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Our topics',
        href: getPermalink('/topics'),
        class: 'px-5 py-3 text-[0.95rem] font-medium',
      },
      {
        text: 'Services',
        href: getPermalink('/services'),
        class: 'px-5 py-3 text-[0.95rem] font-medium',
      },
    ]}
  >
    <Fragment slot="title"><span class="text-[rgb(38_37_35)]">AI-Phil Consulting</span></Fragment>

    <Fragment slot="subtitle">Don’t lose your bearings with AI.<br />Use it wisely.</Fragment>

    <HeroMark slot="ornament" />

    <Fragment slot="content">
      <div
        class="mt-1 max-w-[34rem] font-sans text-[1.08rem] leading-[1.82] text-[rgb(79_82_84)] sm:mt-2 lg:mt-0 lg:flex lg:h-full lg:max-w-[34rem] lg:flex-col"
      >
        <div>
          <p class="max-w-[34rem]">
            Humanity is stepping into the deepest and fastest technological revolution in its history.
          </p>
          <p class="mt-5 max-w-[34rem] lg:mt-6">
            In this new age of discovery, the maps drawn by previous generations can no longer guide us through the
            terrain ahead.
          </p>
          <p class="mt-5 max-w-[34rem] lg:mt-6">
            Curiosity, creativity and critical thinking are the forces that orient our new compasses. Through them, the
            insights of the past find new paths.
          </p>
        </div>
        <p
          class="mt-10 max-w-[34rem] text-[1.08rem] font-medium tracking-[0.01em] text-accent lg:mt-auto lg:-translate-y-2"
        >
          <br />AI-Phil Consulting tunes timeless wisdom into the AI age.
        </p>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(174,157,133,0.06),_transparent_44%)]"></div>
      <div
        class="absolute right-[11%] top-[7rem] hidden h-[27rem] w-[27rem] rounded-full border border-[rgba(47,93,124,0.06)] lg:block"
      >
      </div>
    </Fragment>
  </Hero>

  <CallToAction
    title="About us"
    subtitle="We are a network of researchers and professionals who share a passion for AI and wisdom, and a commitment to careful thinking, honest communication, and real-world impact."
    actions={[{ text: 'Learn more', href: getPermalink('/about') }]}
    classes={{ container: 'pt-0' }}
  />
  <CallToAction
    title="Join us"
    subtitle="Researchers and professionals interested in contributing to talks, workshops, panels, or advisory work are invited to get in touch."
    actions={[{ text: 'Fill the form', href: getPermalink('/join-us') }]}
    classes={{ container: 'pt-0' }}
  />
</Layout>
