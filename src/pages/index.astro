---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import HeroMark from '~/components/hero/HeroMark.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import EditorialServices from '~/components/widgets/EditorialServices.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { formatItems, homeWisdoms, topicItems, whatWeDoItems } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'AI-Phil Consulting',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Explore our topics',
        href: getPermalink('/topics'),
        class: 'px-5 py-3 text-[0.95rem] font-medium',
      },
      {
        text: 'Services',
        href: getPermalink('/services'),
        class: 'px-5 py-3 text-[0.95rem] font-medium',
      },
    ]}
  >
    <Fragment slot="title">AI-Phil Consulting</Fragment>

    <Fragment slot="subtitle">Don’t lose your bearings with AI.<br />Use it wisely.</Fragment>

    <HeroMark slot="ornament" />

    <Fragment slot="content">
      <div class="mt-1 max-w-[34rem] font-sans text-[1.08rem] leading-[1.82] text-[rgb(39_44_52_/_.82)] sm:mt-2 lg:mt-0 lg:flex lg:h-full lg:max-w-[34rem] lg:flex-col">
        <div>
          <p class="max-w-[34rem]">
            Humanity is stepping into the deepest and fastest technological revolution in its history.
            A fertile field of knowledge, applications and possibilities unveils uncharted territories.
            In this new age of discovery, the maps drawn by previous generations can no longer guide us through the terrain ahead.
          </p>
          <p class="mt-5 max-w-[34rem] lg:mt-6">
            Curiosity, creativity and critical thinking are the forces that orient our new compasses. Through them, the insights of the past find new paths.
          </p>
        </div>
        <p class="mt-10 max-w-[34rem] text-[1.08rem] font-medium tracking-[0.01em] text-secondary lg:mt-auto lg:-translate-y-2">
          <br />AI-Phil Consulting tunes timeless wisdom into the AI age.
        </p>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(154,122,88,0.045),_transparent_42%)]"></div>
      <div class="absolute right-[11%] top-[7rem] hidden h-[27rem] w-[27rem] rounded-full border border-[rgba(39,56,78,0.02)] lg:block"></div>
    </Fragment>
  </Hero>

  <Features3
    title="Wisdom in the Age of AI"
    subtitle="Intelligence expands what we can do. Wisdom determines what is worth doing."
    columns={3}
    items={homeWisdoms}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-11 h-11 mb-5 text-primary',
      },
    }}
  />

  <EditorialServices
    tagline="What we provide"
    title="Thinking through your hardest questions"
    items={whatWeDoItems}
    actions={[{ text: 'Browse our services', href: getPermalink('/services'), variant: 'secondary' }]}
    classes={{ container: 'pt-4 md:pt-6 lg:pt-8' }}
  />

  <Features2
    title="Services"
    subtitle="Formats designed for organisations, institutions, and teams that need clear thinking on AI."
    columns={4}
    items={formatItems}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-10 h-10 mb-5 text-accent',
      },
    }}
  />

  <Features2
    title="Topics preview"
    subtitle="Selected areas of inquiry for talks, panels, workshops, and advisory work."
    columns={3}
    items={topicItems}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-10 h-10 mb-5 text-primary',
      },
    }}
  />

  <CallToAction
    title="Services"
    subtitle="AI-Phil Consulting offers talks, panels, workshops, and advisory analysis for organisations engaging seriously with AI."
    actions={[{ text: 'Services', href: getPermalink('/services') }]}
    classes={{ container: 'pt-8' }}
  />

  <CallToAction
    title="About AI-Phil Consulting"
    subtitle="AI-Phil Consulting was founded in Paris to provide independent, intellectually rigorous perspectives on artificial intelligence."
    actions={[{ text: 'About', href: getPermalink('/about') }]}
    classes={{ container: 'pt-0' }}
  />

  <CallToAction
    title="Join us"
    subtitle="Researchers and professionals interested in contributing to talks, workshops, panels, or advisory work are invited to get in touch."
    actions={[{ text: 'Join us', href: getPermalink('/join-us') }]}
    classes={{ container: 'pt-0' }}
  />

  <CallToAction
    title="Contact"
    subtitle="If you would like to discuss talks, workshops, or advisory requests, we would be glad to hear from you."
    actions={[{ text: 'Contact', href: getPermalink('/contact') }]}
    classes={{ container: 'pt-0 pb-20' }}
  />
</Layout>
