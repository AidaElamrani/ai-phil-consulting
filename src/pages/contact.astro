---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Contact from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Contact"
    title="Start a conversation"
    subtitle="AI-Phil Consulting welcomes enquiries about topics, services, collaborations, and other requests."
  />

  <Contact
    title="Contact form"
    subtitle="Use the form below to send an email to contact@ai-phil.consulting."
    action="mailto:contact@ai-phil.consulting"
    method="post"
    enctype="text/plain"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
        autocomplete: 'name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
        autocomplete: 'email',
      },
      {
        type: 'text',
        name: 'organisation',
        label: 'Organisation',
        autocomplete: 'organization',
      },
    ]}
    textarea={{
      label: 'Message',
      name: 'message',
      rows: 6,
    }}
    button="Send email"
    description="Submitting this form opens your email client with the message addressed to contact@ai-phil.consulting."
  />

  <Features2
    title="Contact"
    columns={3}
    items={[
      {
        title: 'Paris based',
        description: 'The consultancy is based in Paris and can support local, national, and international collaborations.',
        icon: 'tabler:building-community',
      },
      {
        title: 'International work possible',
        description: 'Remote and cross-border engagements are possible depending on format, audience, and scope.',
        icon: 'tabler:world',
      },
      {
        title: 'Confidentiality respected',
        description: 'Requests and early conversations are approached with discretion and appropriate confidentiality.',
        icon: 'tabler:lock',
      },
    ]}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-10 h-10 mb-5 text-primary',
      },
    }}
  />
</Layout>
