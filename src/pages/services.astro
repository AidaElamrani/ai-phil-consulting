---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Services',
};

const conferenceItems = [
  {
    title: 'Talks',
    icon: 'tabler:microphone-2',
    description:
      'Short and medium-length presentations designed to introduce, clarify, or deepen understanding of a topic.',
    chips: ['Duration: 10 to 90 minutes', 'Format: presentation + Q&A', 'Best for: conferences, seminars, public events, training'],
  },
  {
    title: 'Panels',
    icon: 'tabler:users-group',
    description:
      'Curated discussions bringing together multiple perspectives on a shared AI-related question.',
    chips: [
      'Duration: 1 to 2 hours',
      'Format: 3–4 experts + moderator + audience questions',
      'Best for: conferences, festivals, institutional events',
    ],
  },
  {
    title: 'Workshops',
    icon: 'tabler:tool',
    description:
      'Interactive formats designed to build understanding and support active engagement.',
    chips: [
      'Duration: half-day to multi-session formats',
      'Format: expert input + group discussions + hands-on sessions',
      'Best for: organizations, education, cultural institutions',
    ],
  },
];

const advisoryItems = [
  {
    title: 'Exploratory Advisory',
    icon: 'tabler:message-circle',
    description:
      'A focused discussion to clarify a question, identify key issues, and explore possible directions.',
    bestFor: 'Best for: early-stage reflection, problem framing, confidential exchange',
    deliverable: 'Deliverable: optional short written summary',
  },
  {
    title: 'Targeted Analysis',
    icon: 'tabler:file-analytics',
    description: 'A structured written analysis addressing a clearly defined AI-related issue.',
    includes: 'Includes: problem definition, background review, analysis, recommendations',
    bestFor: 'Best for: decision support, project review, strategic clarification',
  },
  {
    title: 'Advisory + Memo',
    icon: 'tabler:notes',
    description:
      'A hybrid format combining expert discussion with a concise written synthesis.',
    bestFor: 'Best for: evolving topics, sensitive questions, internal alignment',
    deliverable: 'Deliverable: short structured memo',
  },
];
---

<Layout metadata={metadata}>
  <section class="px-4 pb-10 pt-16 sm:px-6 sm:pt-20 lg:pb-14 lg:pt-24">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-secondary/75">Services</p>
        <h1 class="mt-4 font-heading text-5xl font-semibold leading-none tracking-[-0.04em] text-heading sm:text-6xl">
          Wisdom, applied to AI.
        </h1>
        <p class="mt-6 max-w-2xl font-sans text-[1.08rem] leading-[1.9] text-[rgb(39_44_52_/_.78)] sm:text-[1.12rem]">
          Each question calls for a different approach.<br />
          Our work is organised into a set of formats — which we combine and adapt to each situation.
        </p>
      </div>
    </div>
  </section>

  <section class="border-y border-stone-200/70 bg-[rgba(255,255,255,0.42)] px-4 py-14 sm:px-6 sm:py-18 lg:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.45fr)_minmax(18rem,0.9fr)] lg:gap-16">
        <div class="max-w-2xl">
          <div class="flex items-center gap-4 text-muted">
            <div class="flex h-12 w-12 items-center justify-center rounded-full border border-stone-200/80 bg-[rgba(255,255,255,0.7)] text-muted transition-colors duration-200 hover:text-accent">
              <Icon name="tabler:compass" class="h-7 w-7" />
            </div>
            <div class="h-px flex-1 bg-stone-200/80"></div>
          </div>
          <p class="mt-8 text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Research</p>
          <h2 class="mt-4 font-heading text-[2.7rem] font-semibold leading-[0.98] tracking-[-0.04em] text-heading sm:text-[3.4rem]">
            Research
          </h2>
          <p class="mt-6 text-[1.08rem] leading-[1.95] text-[rgb(39_44_52_/_.78)] sm:text-[1.12rem]">
            In-depth investigation of complex or open-ended questions related to AI, combining conceptual analysis,
            interdisciplinary perspectives, and, where relevant, technical or empirical elements.
          </p>
        </div>

        <div class="rounded-[1.75rem] border border-stone-200/80 bg-[rgba(255,255,255,0.68)] p-6 shadow-[0_18px_50px_rgba(27,31,36,0.04)] sm:p-8">
          <dl class="space-y-6">
            <div>
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Duration</dt>
              <dd class="mt-2 text-[1rem] leading-[1.8] text-[rgb(39_44_52_/_.76)]">
                from a few weeks to several months
              </dd>
            </div>
            <div class="border-t border-stone-200/80 pt-6">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Format</dt>
              <dd class="mt-2 text-[1rem] leading-[1.8] text-[rgb(39_44_52_/_.76)]">
                iterative collaboration with regular exchanges and intermediate outputs
              </dd>
            </div>
            <div class="border-t border-stone-200/80 pt-6">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Best for</dt>
              <dd class="mt-3">
                <ul class="space-y-2 text-[1rem] leading-[1.8] text-[rgb(39_44_52_/_.76)]">
                  <li>evolving or poorly defined questions</li>
                  <li>exploratory or forward-looking topics</li>
                  <li>foundational work preceding strategic decisions</li>
                </ul>
              </dd>
            </div>
            <div class="border-t border-stone-200/80 pt-6">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Deliverables</dt>
              <dd class="mt-3">
                <ul class="space-y-2 text-[1rem] leading-[1.8] text-[rgb(39_44_52_/_.76)]">
                  <li>research reports</li>
                  <li>structured briefs or notes</li>
                  <li>presentations and discussion sessions</li>
                </ul>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 sm:py-18 lg:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Conferences & Workshops</p>
        <h2 class="mt-4 font-heading text-[2.45rem] font-semibold leading-[1.02] tracking-[-0.04em] text-heading sm:text-[3rem]">
          Conferences & Workshops
        </h2>
        <p class="mt-5 text-[1.04rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
          Formats designed to share knowledge, stimulate discussion, and support collective understanding of
          AI-related questions.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          conferenceItems.map((item) => (
            <article class="group rounded-[1.75rem] border border-stone-200/80 bg-[rgba(255,255,255,0.72)] p-7 shadow-[0_16px_40px_rgba(27,31,36,0.04)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_20px_44px_rgba(27,31,36,0.08)]">
              <div class="flex h-12 w-12 items-center justify-center rounded-full border border-stone-200/80 bg-stone-50/70 text-muted transition-colors duration-200 group-hover:text-accent">
                <Icon name={item.icon} class="h-7 w-7" />
              </div>
              <h3 class="mt-6 font-heading text-[2rem] font-semibold leading-none tracking-[-0.03em] text-heading">
                {item.title}
              </h3>
              <p class="mt-4 text-[0.99rem] leading-[1.85] text-[rgb(39_44_52_/_.74)]">{item.description}</p>
              <div class="mt-6 flex flex-wrap gap-2.5">
                {item.chips.map((chip) => (
                  <span class="rounded-full border border-stone-200/85 bg-stone-50/80 px-3 py-1.5 text-[0.78rem] font-medium leading-[1.45] text-[rgb(39_44_52_/_.68)]">
                    {chip}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-y border-stone-200/70 bg-[rgba(255,255,255,0.34)] px-4 py-14 sm:px-6 sm:py-18 lg:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Advisory & Analysis</p>
        <h2 class="mt-4 font-heading text-[2.45rem] font-semibold leading-[1.02] tracking-[-0.04em] text-heading sm:text-[3rem]">
          Advisory & Analysis
        </h2>
        <p class="mt-5 text-[1.04rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
          Focused formats designed to support reflection, clarify issues, and inform decisions.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          advisoryItems.map((item) => (
            <article class="group rounded-[1.75rem] border border-stone-200/80 bg-[rgba(255,255,255,0.76)] p-7 shadow-[0_16px_40px_rgba(27,31,36,0.04)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_20px_44px_rgba(27,31,36,0.08)]">
              <div class="flex h-12 w-12 items-center justify-center rounded-full border border-stone-200/80 bg-stone-50/70 text-muted transition-colors duration-200 group-hover:text-accent">
                <Icon name={item.icon} class="h-7 w-7" />
              </div>
              <h3 class="mt-6 font-heading text-[2rem] font-semibold leading-none tracking-[-0.03em] text-heading">
                {item.title}
              </h3>
              <p class="mt-4 text-[0.99rem] leading-[1.85] text-[rgb(39_44_52_/_.74)]">{item.description}</p>
              {item.includes && <p class="mt-5 text-[0.88rem] leading-[1.7] text-[rgb(39_44_52_/_.68)]">{item.includes}</p>}
              <p class="mt-3 text-[0.88rem] leading-[1.7] text-[rgb(39_44_52_/_.68)]">{item.bestFor}</p>
              {item.deliverable && (
                <p class="mt-3 text-[0.88rem] leading-[1.7] text-[rgb(39_44_52_/_.68)]">{item.deliverable}</p>
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
    <div class="mx-auto max-w-4xl rounded-[2rem] border border-stone-200/80 bg-[rgba(255,255,255,0.56)] px-6 py-12 text-center shadow-[0_18px_50px_rgba(27,31,36,0.04)] sm:px-10 sm:py-14">
      <h2 class="font-heading text-[2.35rem] font-semibold leading-[1.02] tracking-[-0.04em] text-heading sm:text-[2.85rem]">
        Need a format tailored to your context?
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-[1.03rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
        We also design custom engagements based on your questions, constraints, and objectives.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={getPermalink('/contact')}
          class="inline-flex items-center justify-center rounded-full border border-secondary/15 bg-secondary px-6 py-3 text-sm font-semibold tracking-[0.01em] text-white transition duration-200 hover:-translate-y-0.5 hover:bg-primary"
        >
          Get in touch
        </a>
        <a
          href={getPermalink('/contact')}
          class="inline-flex items-center justify-center rounded-full border border-stone-300 bg-transparent px-6 py-3 text-sm font-semibold tracking-[0.01em] text-heading transition duration-200 hover:-translate-y-0.5 hover:border-stone-400 hover:bg-white/70"
        >
          Discuss your project
        </a>
      </div>
    </div>
  </section>
</Layout>
