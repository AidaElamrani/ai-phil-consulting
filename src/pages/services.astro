---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Services',
};

const metadataChipClass =
  'rounded-full border border-stone-200/85 bg-stone-50/80 px-3 py-1.5 text-[0.78rem] font-medium leading-[1.45] text-[rgb(39_44_52_/_.68)]';

const conferenceItems = [
  {
    id: 'talks',
    title: 'Talks',
    icon: 'tabler:microphone-2',
    description:
      'Short and medium-length presentations designed to introduce, clarify, or deepen understanding of a topic.',
    chips: ['Duration: 10 to 90 minutes', 'Format: presentation + Q&A', 'Best for: conferences, seminars, public events, training'],
  },
  {
    id: 'panels',
    title: 'Panels',
    icon: 'tabler:users-group',
    description:
      'Curated discussions bringing together multiple perspectives on a shared AI-related question.',
    chips: [
      'Duration: 1 to 2 hours',
      'Format: 3–4 experts + moderator + audience questions',
      'Best for: conferences, festivals, institutional events',
    ],
  },
  {
    id: 'workshops',
    title: 'Workshops',
    icon: 'tabler:tool',
    description:
      'Interactive formats designed to build understanding and support active engagement.',
    chips: [
      'Duration: half-day to multi-session formats',
      'Format: expert input + group discussions + hands-on sessions',
      'Best for: organizations, education, cultural institutions',
    ],
  },
];

const advisoryItems = [
  {
    id: 'advisory',
    title: 'Exploratory',
    icon: 'tabler:message-circle',
    description:
      'A focused discussion to clarify a question, identify key issues, and explore possible directions.',
    chips: [
      'Best for: early-stage reflection, problem framing, confidential exchange',
      'Deliverable: optional short written summary',
    ],
  },
  {
    title: 'Targeted',
    icon: 'tabler:file-analytics',
    description: 'A structured written analysis addressing a clearly defined AI-related issue.',
    chips: [
      'Format: problem definition, background review, analysis, recommendations',
      'Best for: decision support, project review, strategic clarification',
    ],
  },
  {
    title: 'Hybrid',
    icon: 'tabler:notes',
    description:
      'A hybrid format combining expert discussion with a concise written synthesis.',
    chips: [
      'Best for: evolving topics, sensitive questions, internal alignment',
      'Deliverable: short structured memo',
    ],
  },
];
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Services"
    title="Start using AI wisely."
    subtitle="Each question calls for a different approach.<br />We combine from these formats and adapt to each situation."
  />

  <section id="research" class="px-4 py-7 sm:px-5 sm:py-9 lg:py-10">
    <div class="mx-auto max-w-5xl">
      <div class="rounded-[2rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.72),rgba(255,255,255,0.5))] px-5 py-6 shadow-[0_18px_50px_rgba(27,31,36,0.04)] sm:px-7 sm:py-7 lg:px-8 lg:py-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(25rem,1.1fr)] lg:items-start lg:gap-7">
        <div class="max-w-[39rem] lg:pt-1">
          <div class="flex items-center gap-3 text-muted">
            <div class="flex h-12 w-12 items-center justify-center rounded-full border border-stone-200/80 bg-white/75 text-muted transition-colors duration-200 hover:text-accent">
              <Icon name="tabler:compass" class="h-7 w-7" />
            </div>
            <div class="h-px max-w-[6.5rem] flex-1 bg-stone-200/80"></div>
          </div>
          <div class="mt-5 max-w-[32rem]">
            <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Research</p>
            <h2 class="mt-2.5 font-heading text-[2.55rem] font-semibold leading-[0.98] tracking-[-0.04em] text-heading sm:text-[3.2rem]">
              Research
            </h2>
          </div>
          <p class="mt-3.5 max-w-[30rem] text-[1.08rem] leading-[1.8] text-[rgb(39_44_52_/_.78)] sm:text-[1.12rem]">
            In-depth investigation of complex or open-ended questions related to AI, combining conceptual analysis,
            interdisciplinary perspectives, and, where relevant, technical or empirical elements.
          </p>
        </div>

        <div class="rounded-[1.75rem] border border-stone-200/70 bg-white/60 p-5 sm:p-6 lg:p-6">
          <dl class="space-y-4.5">
            <div>
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Duration</dt>
              <dd class="mt-2.5">
                <span class={metadataChipClass}>From a few weeks to several months</span>
              </dd>
            </div>
            <div class="border-t border-stone-200/75 pt-4.5">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Format</dt>
              <dd class="mt-2.5">
                <span class={metadataChipClass}>
                  Iterative collaboration with regular exchanges and intermediate outputs
                </span>
              </dd>
            </div>
            <div class="border-t border-stone-200/75 pt-4.5">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Best for</dt>
              <dd class="mt-2.5">
                <span class={metadataChipClass}>
                  Evolving or poorly defined questions, exploratory or forward-looking topics, foundational work preceding strategic decisions
                </span>
              </dd>
            </div>
            <div class="border-t border-stone-200/75 pt-4.5">
              <dt class="text-[0.74rem] font-semibold uppercase tracking-[0.2em] text-secondary/70">Deliverables</dt>
              <dd class="mt-2.5">
                <span class={metadataChipClass}>
                  Research reports, structured briefs or notes, presentations and discussion sessions
                </span>
              </dd>
            </div>
          </dl>
      </div>
      </div>
    </div>
    </div>
  </section>

  <section class="bg-[rgba(255,255,255,0.34)] px-4 py-14 sm:px-6 sm:py-18 lg:py-20">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Conferences & Workshops</p>
        <p class="mt-5 text-[1.04rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
          Formats designed to share knowledge, stimulate discussion, and support collective understanding of
          AI-related questions.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          conferenceItems.map((item) => (
            <article id={item.id} class="group flex h-full flex-col rounded-[1.75rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.8),rgba(255,255,255,0.64))] p-7 shadow-[0_14px_32px_rgba(27,31,36,0.035)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(27,31,36,0.07)]">
              <div class="flex items-center gap-3.5">
                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-stone-200/80 bg-stone-50/80 text-muted transition-colors duration-200 group-hover:text-accent">
                  <Icon name={item.icon} class="h-5 w-5" />
                </div>
                <h3 class="font-heading text-[2rem] font-semibold leading-none tracking-[-0.03em] text-heading">
                  {item.title}
                </h3>
              </div>
              <p class="mt-4 text-[0.99rem] leading-[1.85] text-[rgb(39_44_52_/_.74)]">{item.description}</p>
              <div class="mt-6 flex flex-wrap gap-2.5 pt-1">
                {item.chips.map((chip) => (
                  <span class={metadataChipClass}>
                    {chip}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 sm:py-18 lg:py-20">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Advisory & Analysis</p>
        <p class="mt-5 text-[1.04rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
          Focused formats designed to support reflection, clarify issues, and inform decisions.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          advisoryItems.map((item) => (
            <article id={item.id} class="group flex h-full flex-col rounded-[1.75rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.82),rgba(255,255,255,0.68))] p-7 shadow-[0_14px_32px_rgba(27,31,36,0.035)] transition duration-200 hover:-translate-y-1 hover:shadow-[0_18px_40px_rgba(27,31,36,0.07)]">
              <div class="flex items-center gap-3.5">
                <div class="flex h-10 w-10 items-center justify-center rounded-full border border-stone-200/80 bg-stone-50/80 text-muted transition-colors duration-200 group-hover:text-accent">
                  <Icon name={item.icon} class="h-5 w-5" />
                </div>
                <h3 class="font-heading text-[2rem] font-semibold leading-none tracking-[-0.03em] text-heading">
                  {item.title}
                </h3>
              </div>
              <p class="mt-4 text-[0.99rem] leading-[1.85] text-[rgb(39_44_52_/_.74)]">{item.description}</p>
              <div class="mt-6 flex flex-wrap gap-2.5 pt-1">
                {item.chips.map((chip) => (
                  <span class={metadataChipClass}>
                    {chip}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>


    </div>
  </section>
</Layout>
