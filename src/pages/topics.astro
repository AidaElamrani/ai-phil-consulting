---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { topicItems } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Topics',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Topics"
    title="Core Knowledge"
    subtitle="We work across a range of topics related to AI, drawing on a core base of knowledge that can be adapted in scope, depth, and format.<br /><br />Each topic can be explored through talks, workshops, research, or advisory work — and combined or tailored to your specific context."
    content='<p class="mt-3 text-sm font-medium tracking-[0.02em] text-secondary/80 motion-safe:animate-hero-fade">These topics provide entry points into complex questions.</p>'
  />

  <section class="px-4 py-12 sm:px-6 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-5xl">
      <div class="max-w-3xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-secondary/75">Areas of Focus</p>
        <h2 class="mt-4 font-heading text-[2.35rem] font-semibold leading-[1.02] tracking-[-0.04em] text-heading sm:text-[2.85rem]">
          Topics for rigorous engagement with AI
        </h2>
        <p class="mt-5 text-[1.03rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
          A curated set of themes designed to support clear thinking, practical discussion, and deeper inquiry across
          technical, ethical, and social dimensions of AI.
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {
          topicItems.map((item) => (
            <article class="group flex h-full flex-col rounded-2xl border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.86),rgba(248,246,242,0.82))] p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:border-stone-300/90 hover:shadow-md sm:p-8">
              <div class="flex items-center gap-4 text-muted">
                <div class="flex h-11 w-11 items-center justify-center rounded-full border border-stone-200/80 bg-white/80 text-muted transition-colors duration-200 group-hover:text-accent">
                  <Icon name={item.icon} class="h-6 w-6" />
                </div>
                <div class="h-px flex-1 bg-stone-200/80"></div>
              </div>

              <h3 class="mt-6 font-heading text-[1.55rem] font-semibold leading-[1.12] tracking-[-0.03em] text-heading sm:text-[1.7rem]">
                {item.title}
              </h3>
              <p class="mt-4 text-[0.99rem] leading-[1.85] text-[rgb(39_44_52_/_.74)]">{item.description}</p>

              <div class="mt-auto pt-8">
                <p class="text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-secondary/70">Available as</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.availableAs?.map((format) => (
                    <a
                      href={format.href}
                      class="inline-flex items-center rounded-full border border-stone-200/85 bg-stone-50/90 px-2.5 py-1 text-xs font-medium leading-[1.4] text-[rgb(39_44_52_/_.66)] transition-colors duration-200 hover:border-accent/25 hover:bg-accent/10 hover:text-accent"
                    >
                      {format.label}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-[rgba(255,255,255,0.34)] px-4 py-16 sm:px-6 sm:py-20 lg:py-24">
    <div class="mx-auto max-w-4xl rounded-[2rem] border border-stone-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.78),rgba(255,255,255,0.56))] px-6 py-12 text-center shadow-[0_18px_50px_rgba(27,31,36,0.04)] sm:px-10 sm:py-14">
      <h2 class="font-heading text-[2.35rem] font-semibold leading-[1.02] tracking-[-0.04em] text-heading sm:text-[2.85rem]">
        Can’t find what you’re looking for?
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-[1.03rem] leading-[1.9] text-[rgb(39_44_52_/_.76)]">
        We also work on more specific or emerging topics. If your question doesn’t fit into these categories, we can
        design a tailored approach based on your needs.
      </p>
      <div class="mt-8 flex items-center justify-center">
        <a
          href={getPermalink('/contact')}
          class="inline-flex items-center justify-center rounded-full border border-secondary/15 bg-secondary px-6 py-3 text-sm font-semibold tracking-[0.01em] text-white transition duration-200 hover:-translate-y-0.5 hover:bg-primary"
        >
          → Get in touch
        </a>
      </div>
    </div>
  </section>
</Layout>
