---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { advisoryItems, formatItems } from '~/data/site';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Work with us',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Work with us"
    title="Formats for organisations, institutions, and public-facing events"
    subtitle="AI-Phil Consulting works through talks, panels, workshops, and advisory formats designed to help teams and audiences think carefully about artificial intelligence."
  />

  <Features2
    title="Formats"
    columns={4}
    items={formatItems}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-10 h-10 mb-5 text-primary',
      },
    }}
  />

  <Features2
    title="Advisory & Analysis"
    subtitle="Independent support can take several forms depending on the stage and scope of the question."
    columns={3}
    items={advisoryItems.map((item) => ({ ...item, icon: 'tabler:file-text' }))}
    classes={{
      items: {
        panel: 'rounded-2xl border border-stone-200 bg-[rgba(255,255,255,0.72)] p-6 shadow-none',
        icon: 'w-10 h-10 mb-5 text-accent',
      },
    }}
  />

  <CallToAction
    title="Discuss a format"
    subtitle="If you are planning a talk, workshop, panel, or advisory engagement, the next step is a short conversation about your context and needs."
    actions={[{ text: 'Contact', href: getPermalink('/contact') }]}
    classes={{ container: 'pt-8 pb-20' }}
  />
</Layout>
